{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fachwerk.dev/schemas/baustein.schema.json",
  "title": "Baustein-Manifest (bausteine/<id>/manifest.yaml) — ADR-0008",
  "description": "Ein eigener Baustein = Verzeichnis mit manifest.yaml + baustein.js (plain JavaScript, ESM, default-Export rechne(eingaenge, ctx)). Null-Toolchain: kein Build noetig.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "version", "eingaenge", "ausgaenge"],
  "properties": {
    "id": {
      "description": "Baustein-Typ-Kennung (klein geschrieben — Stdlib ist GROSS, dadurch kollisionsfrei).",
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "beschreibung": { "type": "string" },
    "eingaenge": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
    },
    "ausgaenge": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
    },
    "parameter": {
      "description": "Default-Parameter (im Gewerk je Knoten überschreibbar).",
      "type": "object"
    },
    "capabilities": {
      "description": "Was der Baustein darf (ADR-0014 V-1). Fehlt der Block, gibt es KEIN Netz; Zustand und Timer bleiben aus Bestandsschutz erlaubt. Editor und CLI zeigen diese Angaben vor der Nutzung — wie App-Berechtigungen.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "netz": {
          "description": "Ausgehende Netzzugriffe über ctx.netz.hole. Nur exakt diese Hosts, nur https (Ausnahme 127.0.0.1/localhost für Tests).",
          "type": "object",
          "additionalProperties": false,
          "required": ["hosts"],
          "properties": {
            "hosts": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "zustand": {
          "description": "Knoten-lokaler Zustand über ctx.zustand (Default true).",
          "type": "boolean"
        },
        "timer": {
          "description": "Timer über ctx.planeTimer/ctx.brichAb (Default true).",
          "type": "boolean"
        }
      }
    },
    "tests": {
      "description": "Testvektoren — `fachwerk baustein test` führt sie in der Sandbox aus.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["eingaenge"],
        "properties": {
          "eingaenge": { "type": "object" },
          "parameter": { "type": "object" },
          "erwartet": {
            "description": "Erwartete Ausgänge; null = keine Ausgabe.",
            "type": ["object", "null"]
          }
        }
      }
    }
  }
}
