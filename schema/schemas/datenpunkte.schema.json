{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fachwerk.dev/schemas/datenpunkte.schema.json",
  "title": "Datenpunkt-Datei (datenpunkte/<gruppe>.yaml) — SPEC-001",
  "description": "Eine Datei buendelt Datenpunkte einer Gruppe. Der volle Schluessel eines Datenpunkts ist <dateiname>.<schluessel>.",
  "type": "object",
  "minProperties": 1,
  "propertyNames": {
    "pattern": "^[a-z][a-z0-9_]*$"
  },
  "additionalProperties": {
    "$ref": "#/$defs/datenpunkt"
  },
  "$defs": {
    "datenpunkt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "klasse", "typ"],
      "properties": {
        "name": {
          "description": "Anzeigename.",
          "type": "string",
          "minLength": 1
        },
        "klasse": {
          "description": "intern = nur in Fachwerk; bus = an Treiber-Adresse gebunden; system = von Fachwerk bereitgestellt.",
          "enum": ["intern", "bus", "system"]
        },
        "typ": {
          "description": "Werttyp (Skeleton: bool/zahl/text; DPT-Feintypen folgen).",
          "enum": ["bool", "zahl", "text"]
        },
        "treiber": {
          "description": "Treiber-Kennung (nur klasse=bus), z. B. knx.",
          "type": "string",
          "minLength": 1
        },
        "adresse": {
          "description": "Treiber-Adresse (nur klasse=bus), z. B. KNX-Gruppenadresse 1/0/1.",
          "type": "string",
          "minLength": 1
        },
        "dpt": {
          "description": "KNX-Datenpunkttyp der Adresse (nur treiber=knx). Default: bool 1.001, zahl 9.001.",
          "enum": ["1.001", "5.001", "9.001"]
        },
        "initial": {
          "description": "Initialwert.",
          "type": ["boolean", "number", "string"]
        },
        "remanent": {
          "description": "Wert ueberlebt Neustart.",
          "type": "boolean",
          "default": false
        },
        "format": {
          "$ref": "#/$defs/wertFormat"
        },
        "protected": {
          "description": "Nie durch Agenten/Bausteine schreibbar (Plan 4.2).",
          "type": "boolean",
          "default": false
        },
        "notizen": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "klasse": { "const": "bus" } }
          },
          "then": {
            "required": ["treiber", "adresse"]
          }
        }
      ]
    },
    "wertFormat": {
      "description": "Darstellungsformat; wirkt nie auf den Semantikwert (ADR-0011 FMT-4).",
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "einheit": { "type": "string" },
        "praefix": { "type": "string" },
        "suffix": { "type": "string" },
        "dezimalstellen": { "type": "integer", "minimum": 0, "maximum": 20 },
        "skalierung": { "type": "number" },
        "offset": { "type": "number" },
        "tausendertrenner": { "type": "boolean" },
        "enum_map": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string" }
        },
        "bool_map": {
          "type": "object",
          "additionalProperties": false,
          "required": ["wahr", "falsch"],
          "properties": {
            "wahr": { "type": "string" },
            "falsch": { "type": "string" }
          }
        },
        "fallback": { "type": "string" },
        "leerwert": { "type": "string" },
        "max_laenge": { "type": "integer", "minimum": 0 },
        "ellipsis": { "type": "string" },
        "muster": { "type": "string" },
        "modus": { "enum": ["absolut", "relativ"] },
        "template": { "type": "string" }
      }
    }
  }
}
