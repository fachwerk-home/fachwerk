{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fachwerk.dev/schemas/logik.schema.json",
  "title": "Logikseite (logik/<seite>.yaml) — expliziter Graph (ADR-0004/0005)",
  "type": "object",
  "additionalProperties": false,
  "required": ["knoten", "kanten"],
  "properties": {
    "notizen": {
      "type": "string"
    },
    "knoten": {
      "description": "Baustein-Instanzen dieser Seite.",
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["baustein"],
        "properties": {
          "baustein": {
            "description": "Baustein-Typ, z. B. NOT.",
            "type": "string",
            "minLength": 1
          },
          "parameter": {
            "description": "Baustein-Parameter (bausteinspezifisch).",
            "type": "object"
          }
        }
      }
    },
    "kanten": {
      "description": "Gerichtete Kanten: dp:<gruppe>.<key> oder <knoten>.<port>.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["von", "nach"],
        "properties": {
          "von": {
            "type": "string",
            "pattern": "^(dp:[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*|[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*)$"
          },
          "nach": {
            "type": "string",
            "pattern": "^(dp:[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*|[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*)$"
          },
          "trigger": {
            "description": "Trigger-Semantik des Ziel-Eingangs (ADR-0005 E-4).",
            "enum": ["on-change", "on-receive"],
            "default": "on-change"
          }
        }
      }
    }
  }
}
